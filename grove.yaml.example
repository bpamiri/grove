# Grove v3 — Configuration
# Copy this to ~/.grove/grove.yaml and customize.

workspace:
  name: My Workspace

# Trees: repos under Grove management
# Each tree wraps a git repo that workers can operate on.
trees:
  # api-server:
  #   path: ~/code/api-server
  #   github: myorg/api-server
  #   branch_prefix: grove/
  #   quality_gates:
  #     tests: true
  #     lint: true
  #
  # frontend:
  #   path: ~/code/frontend
  #   github: myorg/frontend
  #   branch_prefix: grove/

# Paths: workflow templates that define the step pipeline per task type.
# Built-in paths (development, research, adversarial, security-audit) are always available.
# Add custom paths here:
paths:
  # ops:
  #   description: Infrastructure/ops tasks
  #   steps: [plan, implement, evaluate]

  pr-review:
    description: Review contributed PR
    steps:
      - ci-check:
          type: gate
          on_failure: verdict
      - review:
          prompt: "Review this contributed PR. Check out the PR branch, read the diff, and write a structured review report to .grove/pr-review.md. Analyze for: backwards compatibility, test coverage, code quality, and adherence to project conventions. Include a clear verdict (Recommend Merge / Request Changes / Needs Discussion) and specific suggested comments per file."
      - verdict

  # The security-audit path is built-in but can be customized here:
  # security-audit:
  #   description: Security audit — dependency scan, SAST, secrets detection, and report
  #   steps:
  #     - scan:
  #         skills: [security-audit]
  #     - analyze:
  #         skills: [security-audit]
  #         sandbox: read-only
  #     - report:
  #         skills: [security-audit]
  #     - remediate:
  #         skills: [security-audit]
  #         on_failure: $done

# Budget controls
budgets:
  per_task: 5.00        # Max spend per individual task
  per_session: 10.00    # Max for a single worker session
  per_day: 25.00        # Daily ceiling
  per_week: 100.00      # Weekly ceiling
  auto_approve_under: 2.00  # Tasks below this cost auto-dispatch

# Server configuration
server:
  port: auto            # Random available port (or pin: 8432)

# Tunnel configuration (remote access)
tunnel:
  provider: cloudflare  # Free quick tunnels, no account needed
  auth: token           # Random token for security
  # For a stable vanity URL on grove.cloud (free, no Cloudflare account needed):
  # domain: grove.cloud
  # subdomain and secret are auto-generated on first start

# General settings
settings:
  max_workers: 5              # Concurrent worker limit
  branch_prefix: grove/       # Default git branch prefix
  stall_timeout_minutes: 5    # Detect stalled workers after this many minutes
  max_retries: 2              # Auto-retry failed evaluations
