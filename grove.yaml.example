# Grove v2 Configuration
# Copy this to ~/.grove/grove.yaml and customize.

workspace:
  name: "My Workshop"

# Repositories Grove manages.
# Each key is a short name used in task IDs and commands.
repos:
  # Example: CFWheels framework
  # wheels:
  #   org: cfwheels
  #   github: cfwheels/wheels
  #   path: ~/code/wheels

  # Example: Titan e-commerce
  # titan:
  #   org: paiindustries
  #   github: paiindustries/titan
  #   path: ~/code/titan

# Budget limits (USD). Grove tracks spend and warns/blocks at thresholds.
budgets:
  per_task: 5.00
  per_session: 10.00
  per_day: 25.00
  per_week: 100.00
  auto_approve_under: 2.00

# Execution settings
settings:
  max_concurrent: 4
  branch_prefix: "grove/"
  auto_sync: false
