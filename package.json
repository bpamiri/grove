{
  "name": "@grove-ai/cli",
  "version": "0.1.11",
  "type": "module",
  "main": "src/cli/index.ts",
  "bin": {
    "grove": "bin/grove"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build:web": "cd web && bun run build",
    "build:embed": "bun run scripts/embed-web.ts",
    "build:bin": "mkdir -p bin && bun build src/cli/index.ts --compile --outfile bin/grove",
    "build": "bun run build:web && bun run build:embed && bun run build:bin",
    "test": "bun test tests/"
  },
  "dependencies": {
    "picocolors": "^1.1",
    "yaml": "^2.7"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "changelogen": "^0.6.2",
    "typescript": "^5.7"
  }
}
